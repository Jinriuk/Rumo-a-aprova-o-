# ============================================================
# Variáveis de ambiente — MODELO. Copie para .env e preencha.
#
# REGRA QUE NÃO SE NEGOCIA: a chave de serviço (service_role)
# NUNCA entra neste repositório nem no front. Ela só existe nas
# variáveis do Supabase (Edge Functions) e na sua máquina, para
# scripts de operador (seed de usuários).
# ============================================================

# --- Front (app/.env) — só chaves PÚBLICAS ---
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=chave-publica-anon

# --- Scripts de operador (scripts/*.mjs) — NUNCA no front ---
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=so-na-sua-maquina-e-no-servidor

# --- Testes locais (tests/) ---
PGHOST=127.0.0.1
PGPORT=54322
PGUSER=postgres
PGDATABASE=rumo_teste
